{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "functions": {
    "api/auth.js":    { "maxDuration": 30 },
    "api/meals.js":   { "maxDuration": 30 },
    "api/analyze.js": { "maxDuration": 60 },
    "api/report.js":  { "maxDuration": 30 },
    "api/admin.js":   { "maxDuration": 30 },
    "api/status.js":  { "maxDuration": 10 },
    "api/migrate.js": { "maxDuration": 60 }
  }
}
